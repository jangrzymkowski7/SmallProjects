<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal"
    android:background="@color/ivory"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kalkulator Liczb Zespolonych"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/fuchsia"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="265dp"
        android:layout_height="wrap_content"
        android:text="Liczba A (Rzeczywista + Urojona)"
        android:textColor="@color/fuchsia"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="40dp"> <EditText
        android:id="@+id/etRealA"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:hint="Część Rzeczywista (A)"
        android:inputType="numberDecimal|numberSigned"
        android:background="@color/black"           android:textColor="@color/lime"        android:textColorHint="@color/lime"       android:padding="8dp"
        android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etImagA"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Część Urojona (A)"
            android:inputType="numberDecimal|numberSigned"
            android:background="@color/black"           android:textColor="@color/lime"        android:textColorHint="@color/lime"       android:padding="8dp"/>
    </LinearLayout>
    <TextView
        android:layout_width="265dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Liczba B (Rzeczywista + Urojona)"
        android:textColor="@color/fuchsia"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp"
        android:layout_marginHorizontal="40dp"> <EditText
        android:id="@+id/etRealB"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:hint="Część Rzeczywista (B)"
        android:inputType="numberDecimal|numberSigned"
        android:background="@color/black"           android:textColor="@color/lime"        android:textColorHint="@color/lime"       android:padding="8dp"
        android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etImagB"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Część Urojona (B)"
            android:inputType="numberDecimal|numberSigned"
            android:background="@color/black"           android:textColor="@color/lime"        android:textColorHint="@color/lime"       android:padding="8dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DODAJ (A + B)"
            android:backgroundTint="@color/crimson"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSubtract"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ODEJMIJ (A - B)"
            android:backgroundTint="@color/crimson"/>
    </LinearLayout>

</LinearLayout>